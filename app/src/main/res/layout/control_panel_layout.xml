<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#E61A1A1A"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎛️ 4모서리 정밀 제어판"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnToggleLogic"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:backgroundTint="#4CAF50"
            android:text="로직: ON"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnToggleGrid"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:backgroundTint="#2196F3"
            android:text="격자 숨기기"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnKillService"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:backgroundTint="#F44336"
            android:text="종료(Kill)"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvGridInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="칸수 설정: 9x11"
            android:textColor="#CCCCCC"
            android:textSize="12sp" />

        <Button android:id="@+id/btnRowMinus" android:layout_width="45dp" android:layout_height="35dp" android:text="행-" android:textSize="11sp" android:padding="0dp"/>
        <Button android:id="@+id/btnRowPlus" android:layout_width="45dp" android:layout_height="35dp" android:text="행+" android:textSize="11sp" android:padding="0dp" android:layout_marginEnd="12dp"/>

        <Button android:id="@+id/btnColMinus" android:layout_width="45dp" android:layout_height="35dp" android:text="열-" android:textSize="11sp" android:padding="0dp"/>
        <Button android:id="@+id/btnColPlus" android:layout_width="45dp" android:layout_height="35dp" android:text="열+" android:textSize="11sp" android:padding="0dp"/>
    </LinearLayout>

    <RadioGroup
        android:id="@+id/rgCornerSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="6dp">
        
        <RadioButton android:id="@+id/rbTL" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="좌상(TL)" android:textColor="#FFFFFF" android:checked="true" android:textSize="11sp" android:layout_marginEnd="6dp"/>
        <RadioButton android:id="@+id/rbTR" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="우상(TR)" android:textColor="#FFFFFF" android:textSize="11sp" android:layout_marginEnd="6dp"/>
        <RadioButton android:id="@+id/rbBL" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="좌하(BL)" android:textColor="#FFFFFF" android:textSize="11sp" android:layout_marginEnd="6dp"/>
        <RadioButton android:id="@+id/rbBR" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="우하(BR)" android:textColor="#FFFFFF" android:textSize="11sp"/>
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button android:id="@+id/btnMoveLeft" android:layout_width="55dp" android:layout_height="35dp" android:text="◀ 좌" android:textSize="11sp" android:padding="0dp"/>
        <LinearLayout 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:orientation="vertical"
            android:layout_marginHorizontal="15dp">
            <Button android:id="@+id/btnMoveUp" android:layout_width="55dp" android:layout_height="33dp" android:text="▲ 상" android:textSize="11sp" android:padding="0dp"/>
            <Button android:id="@+id/btnMoveDown" android:layout_width="55dp" android:layout_height="33dp" android:text="▼ 하" android:textSize="11sp" android:padding="0dp"/>
        </LinearLayout>
        <Button android:id="@+id/btnMoveRight" android:layout_width="55dp" android:layout_height="35dp" android:text="▶ 우" android:textSize="11sp" android:padding="0dp"/>
    </LinearLayout>
</LinearLayout>
